<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Every Paw | Pet Sitting & Care · North London</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
  :root {
    --cream: #F5F0E8;
    --warm-white: #FDFAF5;
    --terracotta: #C4622D;
    --terracotta-light: #E8845A;
    --bark: #3D2B1F;
    --bark-mid: #6B4C3B;
    --sage: #7A8C6E;
    --sage-light: #B8C5AE;
    --sand: #D4B896;
    --sand-light: #EAD9C4;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--warm-white);
    color: var(--bark);
    overflow-x: hidden;
  }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 3rem;
    background: rgba(253,250,245,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(196,98,45,0.12);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    color: var(--terracotta);
    letter-spacing: -0.02em;
  }
  .nav-logo span { font-style: italic; }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a {
    text-decoration: none;
    color: var(--bark-mid);
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--terracotta); }
  .nav-cta {
    background: var(--terracotta);
    color: white !important;
    padding: 0.55rem 1.4rem;
    border-radius: 50px;
    transition: background 0.2s !important;
  }
  .nav-cta:hover { background: var(--bark) !important; color: white !important; }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-top: 80px;
    position: relative;
    overflow: hidden;
  }
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 4rem 6rem 5rem;
    position: relative;
    z-index: 2;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px; height: 1.5px;
    background: var(--terracotta);
  }
  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 4.8rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--bark);
    margin-bottom: 1.8rem;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--terracotta);
  }
  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--bark-mid);
    max-width: 460px;
    margin-bottom: 2.8rem;
  }
  .hero-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .btn-primary {
    background: var(--terracotta);
    color: white;
    padding: 0.9rem 2.2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.25s;
    box-shadow: 0 4px 20px rgba(196,98,45,0.25);
  }
  .btn-primary:hover {
    background: var(--bark);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(61,43,31,0.2);
  }
  .btn-secondary {
    color: var(--bark-mid);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    display: flex; align-items: center; gap: 0.5rem;
    transition: color 0.2s;
  }
  .btn-secondary:hover { color: var(--terracotta); }
  .hero-badges {
    display: flex; gap: 1.5rem; margin-top: 3.5rem; flex-wrap: wrap;
  }
  .badge {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--bark-mid);
    font-weight: 500;
  }
  .badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--sage);
  }

  .hero-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--cream);
    overflow: hidden;
  }
  .hero-illustration {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  /* Large decorative paw */
  .hero-paw-bg {
    position: absolute;
    font-size: 22rem;
    opacity: 0.07;
    color: var(--terracotta);
    user-select: none;
    animation: floatPaw 6s ease-in-out infinite;
  }
  @keyframes floatPaw {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-18px) rotate(2deg); }
  }
  .hero-card {
    position: relative;
    z-index: 2;
    background: white;
    border-radius: 24px;
    padding: 2.5rem 2rem;
    width: 320px;
    box-shadow: 0 20px 60px rgba(61,43,31,0.12);
    animation: cardFloat 5s ease-in-out infinite;
  }
  @keyframes cardFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .hero-card-top {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .card-avatar {
    width: 52px; height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--terracotta-light), var(--terracotta));
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
  }
  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.1rem;
    color: var(--bark);
  }
  .card-sub {
    font-size: 0.78rem;
    color: var(--bark-mid);
    margin-top: 0.15rem;
  }
  .card-stars {
    color: #F5A623;
    font-size: 0.85rem;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }
  .card-quote {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--bark-mid);
    font-style: italic;
  }
  .card-tag {
    display: inline-block;
    margin-top: 1.2rem;
    background: var(--cream);
    color: var(--terracotta);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
  }
  .floating-tag {
    position: absolute;
    background: var(--terracotta);
    color: white;
    padding: 0.6rem 1.1rem;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 500;
    box-shadow: 0 6px 20px rgba(196,98,45,0.3);
    animation: tagFloat 4s ease-in-out infinite;
  }
  .floating-tag-1 { top: 25%; left: 8%; animation-delay: 0s; }
  .floating-tag-2 { bottom: 28%; right: 6%; animation-delay: 1.5s; }
  @keyframes tagFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* ABOUT STRIP */
  .about-strip {
    background: var(--bark);
    color: white;
    padding: 4rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .about-photo {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 3/4;
    position: relative;
  }
  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    filter: sepia(10%) contrast(1.05);
  }
  .about-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 20px;
    border: 1.5px solid rgba(255,255,255,0.1);
    pointer-events: none;
  }
  .about-strip h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }
  .about-strip h2 em { font-style: italic; color: var(--terracotta-light); }
  .about-strip p {
    font-size: 0.98rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1rem;
  }
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .stat-box {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 1.5rem;
    transition: background 0.2s;
  }
  .stat-box:hover { background: rgba(255,255,255,0.1); }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    color: var(--terracotta-light);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .stat-label {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.4;
  }

  /* SPECIAL NEEDS BANNER */
  .special-banner {
    background: linear-gradient(135deg, var(--terracotta) 0%, #A0461C 100%);
    color: white;
    padding: 3rem 5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .special-icon { font-size: 3rem; flex-shrink: 0; }
  .special-banner h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
  }
  .special-banner p {
    font-size: 0.95rem;
    line-height: 1.7;
    opacity: 0.9;
    max-width: 700px;
  }

  /* SERVICES */
  .services {
    padding: 6rem 5rem;
    background: var(--warm-white);
  }
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .section-eyebrow {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--terracotta);
    margin-bottom: 0.8rem;
  }
  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--bark);
    line-height: 1.15;
  }
  .section-header h2 em { font-style: italic; color: var(--terracotta); }
  .section-header p {
    margin-top: 1rem;
    font-size: 1rem;
    color: var(--bark-mid);
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.75;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .service-card {
    background: white;
    border-radius: 20px;
    padding: 2.2rem 2rem;
    border: 1.5px solid var(--sand-light);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .service-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--terracotta), var(--terracotta-light));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .service-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(61,43,31,0.1); border-color: var(--sand); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-icon {
    width: 54px; height: 54px;
    background: var(--cream);
    border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem;
    margin-bottom: 1.4rem;
  }
  .service-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: var(--bark);
    margin-bottom: 0.7rem;
  }
  .service-card p {
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--bark-mid);
    margin-bottom: 1.4rem;
  }
  .service-price {
    display: flex; align-items: baseline; gap: 0.3rem;
  }
  .price-from { font-size: 0.75rem; color: var(--bark-mid); }
  .price-amount {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    color: var(--terracotta);
    font-weight: 700;
  }
  .price-unit { font-size: 0.78rem; color: var(--bark-mid); }
  .service-special {
    display: inline-block;
    background: var(--cream);
    color: var(--sage);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.25rem 0.7rem;
    border-radius: 20px;
    margin-top: 0.8rem;
  }

  /* WHY */
  .why {
    background: var(--cream);
    padding: 6rem 5rem;
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-top: 4rem;
  }
  .why-item { text-align: center; }
  .why-icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    display: block;
  }
  .why-item h4 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: var(--bark);
    margin-bottom: 0.5rem;
  }
  .why-item p {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--bark-mid);
  }

  /* TESTIMONIALS */
  .testimonials {
    padding: 6rem 5rem;
    background: var(--warm-white);
  }
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }
  .testi-card {
    background: var(--cream);
    border-radius: 20px;
    padding: 2rem;
    border: 1.5px solid var(--sand-light);
  }
  .testi-stars { color: #F5A623; margin-bottom: 1rem; font-size: 0.9rem; }
  .testi-text {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--bark-mid);
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  .testi-author {
    display: flex; align-items: center; gap: 0.8rem;
  }
  .testi-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--sand), var(--terracotta-light));
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
  }
  .testi-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--bark);
  }
  .testi-area { font-size: 0.75rem; color: var(--bark-mid); }

  /* PRICING */
  .pricing {
    background: var(--bark);
    padding: 6rem 5rem;
    color: white;
  }
  .pricing .section-header h2 { color: white; }
  .pricing .section-header p { color: rgba(255,255,255,0.65); }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 4rem;
  }
  .pricing-card {
    background: rgba(255,255,255,0.05);
    border: 1.5px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    padding: 2.2rem 2rem;
    transition: all 0.3s;
  }
  .pricing-card.featured {
    background: var(--terracotta);
    border-color: var(--terracotta);
    transform: scale(1.04);
  }
  .pricing-card:hover:not(.featured) {
    background: rgba(255,255,255,0.08);
    transform: translateY(-4px);
  }
  .pricing-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 0.5rem;
  }
  .pricing-card h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
  }
  .pricing-price {
    display: flex; align-items: baseline; gap: 0.3rem;
    margin-bottom: 1.8rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .pp-from { font-size: 0.8rem; opacity: 0.7; }
  .pp-amount {
    font-family: 'Playfair Display', serif;
    font-size: 2.8rem;
    line-height: 1;
  }
  .pp-unit { font-size: 0.85rem; opacity: 0.7; }
  .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .pricing-features li {
    font-size: 0.87rem;
    opacity: 0.85;
    display: flex; align-items: center; gap: 0.6rem;
  }
  .pricing-features li::before {
    content: '✓';
    width: 18px; height: 18px;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.65rem;
    flex-shrink: 0;
  }
  .pricing-note {
    text-align: center;
    margin-top: 2.5rem;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5);
  }
  .pricing-note a { color: var(--terracotta-light); text-decoration: none; }

  /* CTA */
  .cta-section {
    background: var(--cream);
    padding: 6rem 5rem;
    text-align: center;
  }
  .cta-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--bark);
    line-height: 1.2;
    margin-bottom: 1.2rem;
  }
  .cta-section h2 em { font-style: italic; color: var(--terracotta); }
  .cta-section p {
    font-size: 1rem;
    color: var(--bark-mid);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    line-height: 1.75;
  }
  .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-outline {
    background: transparent;
    color: var(--bark);
    padding: 0.9rem 2.2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border: 1.5px solid var(--bark);
    transition: all 0.25s;
  }
  .btn-outline:hover { background: var(--bark); color: white; }

  /* FOOTER */
  footer {
    background: var(--bark);
    color: white;
    padding: 3rem 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1.5rem;
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--terracotta-light);
  }
  .footer-logo span { font-style: italic; }
  .footer-links { display: flex; gap: 2rem; }
  .footer-links a {
    text-decoration: none;
    color: rgba(255,255,255,0.55);
    font-size: 0.85rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: white; }
  .footer-copy { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

  /* ANIMATIONS */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeUp 0.7s ease forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.25s; }
  .delay-3 { animation-delay: 0.4s; }
  .delay-4 { animation-delay: 0.55s; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 5rem 2rem 3rem; }
    .hero-right { min-height: 380px; }
    .about-strip { grid-template-columns: 1fr; padding: 3rem 2rem; gap: 2rem; } .about-photo { aspect-ratio: 4/3; }
    .special-banner { padding: 2.5rem 2rem; flex-direction: column; text-align: center; }
    .services { padding: 4rem 2rem; }
    .services-grid { grid-template-columns: 1fr; }
    .why { padding: 4rem 2rem; }
    .why-grid { grid-template-columns: 1fr 1fr; }
    .testimonials { padding: 4rem 2rem; }
    .testi-grid { grid-template-columns: 1fr; }
    .pricing { padding: 4rem 2rem; }
    .pricing-grid { grid-template-columns: 1fr; }
    .pricing-card.featured { transform: scale(1); }
    .cta-section { padding: 4rem 2rem; }
    footer { padding: 2.5rem 2rem; flex-direction: column; text-align: center; }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Every <span>Paw</span></div>
  <ul class="nav-links">
    <li><a href="#services">Services</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#pricing">Pricing</a></li>
    <li><a href="#testimonials">Reviews</a></li>
    <li><a href="#contact" class="nav-cta">Book Now</a></li>
  </ul>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow fade-up">North London · Est. 2015</div>
    <h1 class="fade-up delay-1">
      Care that goes<br/><em>beyond the bowl.</em>
